// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// I. Identity & Access
model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  password           String
  name               String
  role               Role                @default(STUDENT)
  avatarUrl          String?             @map("avatar_url")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  skills             UserSkill[]
  notifications      Notification[]
  coursesCreated     Course[]            @relation("CourseCreator")
  learningPaths      LearningPath[]      @relation("PathCreator")
  enrollments        Enrollment[]
  studySessions      StudySession[]
  certificates       Certificate[]
  assessmentAttempts AssessmentAttempt[]
  interactions       Interaction[]
  aiFeedback         AiFeedback[]
  bookmarks          Bookmark[]
  courseReviews      CourseReview[]
  threads            DiscussionThread[]
  replies            DiscussionReply[]

  @@map("users")
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

model UserSkill {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  skillTag    String   @map("skill_tag")
  proficiency Int
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("user_skills")
}

model Notification {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id])
  type        String
  payloadJson Json      @map("payload_json")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("notifications")
}

// II. Course Catalogue
model Course {
  id            String               @id @default(uuid())
  title         String
  slug          String               @unique
  description   String
  level         CourseLevel          @default(BEGINNER)
  tags          String[]
  thumbnailUrl  String?              @map("thumbnail_url")
  createdBy     String               @map("created_by")
  creator       User                 @relation("CourseCreator", fields: [createdBy], references: [id])
  createdAt     DateTime             @default(now()) @map("created_at")
  modules       Module[]
  learningPaths LearningPathCourse[]
  enrollments   Enrollment[]
  studySessions StudySession[]
  certificates  Certificate[]
  assessments   Assessment[]
  docSources    DocumentSource[]
  aiConfigs     AiModelConfig[]
  reviews       CourseReview[]
  interactions  Interaction[]

  @@map("courses")
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Module {
  id          String             @id @default(uuid())
  courseId    String             @map("course_id")
  course      Course             @relation(fields: [courseId], references: [id])
  title       String
  contentType ModuleType         @map("content_type")
  body        String
  order       Int
  durationS   Int                @map("duration_s")
  versions    ContentVersion[]
  progress    ProgressTracking[]
  assessments Assessment[]
  ragContext  RagContext[]
  bookmarks   Bookmark[]
  threads     DiscussionThread[]

  @@map("modules")
}

enum ModuleType {
  VIDEO
  TEXT
  CODE
}

model LearningPath {
  id          String               @id @default(uuid())
  title       String
  description String
  createdBy   String               @map("created_by")
  creator     User                 @relation("PathCreator", fields: [createdBy], references: [id])
  tags        String[]
  courses     LearningPathCourse[]
  enrollments Enrollment[]

  @@map("learning_paths")
}

model LearningPathCourse {
  id       String       @id @default(uuid())
  pathId   String       @map("path_id")
  path     LearningPath @relation(fields: [pathId], references: [id])
  courseId String       @map("course_id")
  course   Course       @relation(fields: [courseId], references: [id])
  order    Int

  @@map("learning_path_courses")
}

model ContentVersion {
  id         String       @id @default(uuid())
  moduleId   String       @map("module_id")
  module     Module       @relation(fields: [moduleId], references: [id])
  version    Int
  body       String
  createdBy  String       @map("created_by")
  createdAt  DateTime     @default(now()) @map("created_at")
  ragContext RagContext[]

  @@map("content_versions")
}

// III. Enrolment & Progress
model Enrollment {
  id          String             @id @default(uuid())
  userId      String             @map("user_id")
  user        User               @relation(fields: [userId], references: [id])
  courseId    String             @map("course_id")
  course      Course             @relation(fields: [courseId], references: [id])
  pathId      String?            @map("path_id")
  path        LearningPath?      @relation(fields: [pathId], references: [id])
  enrolledAt  DateTime           @default(now()) @map("enrolled_at")
  completedAt DateTime?          @map("completed_at")
  progress    ProgressTracking[]

  @@map("enrollments")
}

model ProgressTracking {
  id           String     @id @default(uuid())
  enrollmentId String     @map("enrollment_id")
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  moduleId     String     @map("module_id")
  module       Module     @relation(fields: [moduleId], references: [id])
  status       String
  timeSpentS   Int        @map("time_spent_s")
  lastPosition String     @map("last_position")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("progress_tracking")
}

model StudySession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  courseId  String   @map("course_id")
  course    Course   @relation(fields: [courseId], references: [id])
  startedAt DateTime @map("started_at")
  endedAt   DateTime @map("ended_at")
  durationS Int      @map("duration_s")

  @@map("study_sessions")
}

model Certificate {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  user     User     @relation(fields: [userId], references: [id])
  courseId String   @map("course_id")
  course   Course   @relation(fields: [courseId], references: [id])
  issuedAt DateTime @default(now()) @map("issued_at")
  certUrl  String   @map("cert_url")
  hash     String

  @@map("certificates")
}

// IV. Assessment
model Assessment {
  id          String               @id @default(uuid())
  moduleId    String?              @map("module_id")
  module      Module?              @relation(fields: [moduleId], references: [id])
  courseId    String               @map("course_id")
  course      Course               @relation(fields: [courseId], references: [id])
  title       String
  passScore   Int                  @map("pass_score")
  maxAttempts Int                  @map("max_attempts")
  timeLimitS  Int                  @map("time_limit_s")
  questions   AssessmentQuestion[]
  attempts    AssessmentAttempt[]

  @@map("assessments")
}

model AssessmentQuestion {
  id           String     @id @default(uuid())
  assessmentId String     @map("assessment_id")
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  type         String
  prompt       String
  optionsJson  Json       @map("options_json")
  answerKey    String     @map("answer_key")
  points       Int

  @@map("assessment_questions")
}

model AssessmentAttempt {
  id           String     @id @default(uuid())
  userId       String     @map("user_id")
  user         User       @relation(fields: [userId], references: [id])
  assessmentId String     @map("assessment_id")
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  score        Int
  answersJson  Json       @map("answers_json")
  passed       Boolean
  startedAt    DateTime   @map("started_at")
  submittedAt  DateTime   @map("submitted_at")

  @@map("assessment_attempts")
}

// V. RAG & AI
model RagContext {
  id         String                       @id @default(uuid())
  moduleId   String                       @map("module_id")
  module     Module                       @relation(fields: [moduleId], references: [id])
  versionId  String                       @map("version_id")
  version    ContentVersion               @relation(fields: [versionId], references: [id])
  chunkText  String                       @map("chunk_text")
  embedding  Unsupported("vector(1536)")? // Using pgvector
  chunkOrder Int                          @map("chunk_order")
  tokenCount Int                          @map("token_count")

  @@map("rag_context")
}

model Interaction {
  id                String       @id @default(uuid())
  userId            String       @map("user_id")
  user              User         @relation(fields: [userId], references: [id])
  courseId          String       @map("course_id")
  course            Course       @relation(fields: [courseId], references: [id])
  role              String
  message           String
  retrievedChunkIds String[]     @map("retrieved_chunk_ids")
  model             String
  createdAt         DateTime     @default(now()) @map("created_at")
  feedback          AiFeedback[]
  bookmarks         Bookmark[]

  @@map("interactions")
}

model DocumentSource {
  id            String   @id @default(uuid())
  courseId      String   @map("course_id")
  course        Course   @relation(fields: [courseId], references: [id])
  title         String
  sourceUrl     String   @map("source_url")
  status        String
  lastCrawledAt DateTime @map("last_crawled_at")
  chunkCount    Int      @map("chunk_count")

  @@map("document_sources")
}

model AiFeedback {
  id            String      @id @default(uuid())
  interactionId String      @map("interaction_id")
  interaction   Interaction @relation(fields: [interactionId], references: [id])
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("ai_feedback")
}

model AiModelConfig {
  id           String   @id @default(uuid())
  courseId     String   @map("course_id")
  course       Course   @relation(fields: [courseId], references: [id])
  modelId      String   @map("model_id")
  temperature  Float
  topK         Int      @map("top_k")
  systemPrompt String   @map("system_prompt")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("ai_model_configs")
}

// VI. Community
model Bookmark {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  user          User         @relation(fields: [userId], references: [id])
  moduleId      String?      @map("module_id")
  module        Module?      @relation(fields: [moduleId], references: [id])
  interactionId String?      @map("interaction_id")
  interaction   Interaction? @relation(fields: [interactionId], references: [id])
  note          String?
  createdAt     DateTime     @default(now()) @map("created_at")

  @@map("bookmarks")
}

model CourseReview {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  courseId  String   @map("course_id")
  course    Course   @relation(fields: [courseId], references: [id])
  rating    Int
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("course_reviews")
}

model DiscussionThread {
  id        String            @id @default(uuid())
  moduleId  String            @map("module_id")
  module    Module            @relation(fields: [moduleId], references: [id])
  authorId  String            @map("author_id")
  author    User              @relation(fields: [authorId], references: [id])
  title     String
  body      String
  pinned    Boolean           @default(false)
  createdAt DateTime          @default(now()) @map("created_at")
  replies   DiscussionReply[]

  @@map("discussion_threads")
}

model DiscussionReply {
  id        String           @id @default(uuid())
  threadId  String           @map("thread_id")
  thread    DiscussionThread @relation(fields: [threadId], references: [id])
  authorId  String           @map("author_id")
  author    User             @relation(fields: [authorId], references: [id])
  body      String
  upvotes   Int              @default(0)
  isAnswer  Boolean          @default(false) @map("is_answer")
  createdAt DateTime         @default(now()) @map("created_at")

  @@map("discussion_replies")
}
